# ── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=5050
# Required in production. In dev, omit to use an ephemeral in-memory MongoDB.
MONGO_URI=
CLIENT_URL=http://localhost:3000

# ── Auth (REQUIRED — use long random strings, >=32 chars in prod) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
MAX_SESSIONS_PER_USER=10
COOKIE_DOMAIN=

# ── AI verification (optional — falls back to manual review if absent) ──
GROQ_API_KEY=
OPENAI_API_KEY=
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_TEXT_MODEL=llama-3.3-70b-versatile

# ── Blockchain (optional — enables server-side tx verification) ──
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=
CONTRACT_ADDRESS=0x...
CHAIN_ID=11155111

# ── Payments (optional — Stripe test mode) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Logging ──
LOG_LEVEL=debug
